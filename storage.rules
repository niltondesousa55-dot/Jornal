rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Permitir leitura pública para todas as imagens e vídeos do portal
      allow read: if true;
      
      // Permitir escrita apenas para utilizadores autenticados (Administradores)
      allow write: if request.auth != null;
    }
  }
}
